generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:/tmp/custom.db"
}

model Settings {
  id                  String   @id @default("default")
  needsPercent        Int      @default(50)
  wantsPercent        Int      @default(30)
  savingsPercent      Int      @default(20)
  savingsCardNumber   String   @default("")
  savingsCardBank     String   @default("payme")
  telegramBotToken    String   @default("")
  telegramChatId      String   @default("")
  reportDayOfWeek     Int      @default(7)
  reportHour          Int      @default(20)
  paymentService      String   @default("payme")
  apiKey              String   @default("")
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
}

model Transaction {
  id              String   @id @default(cuid())
  amount          Int
  needsAmount     Int
  wantsAmount     Int
  savingsAmount   Int
  savingsTransferred Boolean @default(false)
  smsText         String
  bankName        String   @default("")
  cardLast4       String   @default("")
  paymentLink     String   @default("")
  confirmedAt     DateTime?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}